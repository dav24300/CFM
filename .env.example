# =============================================================================
# CFM ASBL — Variables d'environnement (source de vérité unique)
# Cible de production : Vercel (hébergement) + Supabase (Postgres + Storage)
# =============================================================================
# Copier ce fichier en .env.local pour le développement.
# Les blocs "OBLIGATOIRE (prod)" doivent être renseignés sur Vercel avant tout
# déploiement de production, sinon l'application plante au démarrage runtime.

# -----------------------------------------------------------------------------
# 1. OBLIGATOIRE (prod) — l'app throw au premier appel serverless si absent
#    (voir src/lib/config.ts)
# -----------------------------------------------------------------------------
# Mot de passe admin (dashboard /admin) — utiliser un mot de passe FORT en prod
ADMIN_PASSWORD=changez-moi-en-production
# Secret session (générer une chaîne aléatoire longue, 64+ caractères)
SESSION_SECRET=remplacer-par-une-cle-secrete-longue
# Chiffrement des données sensibles (aide confidentielle) — 32 caractères minimum
DATA_ENCRYPTION_KEY=generer-une-cle-aleatoire-32-caracteres-minimum

# -----------------------------------------------------------------------------
# 2. Site
# -----------------------------------------------------------------------------
# URL publique du site (emails, callbacks PayDunya)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Téléphone de contact affiché sur le site public
NEXT_PUBLIC_CONTACT_PHONE=

# -----------------------------------------------------------------------------
# 3. Persistance PostgreSQL (Supabase) — OBLIGATOIRE (prod)
#    Sans DATABASE_URL, fallback JSON local ÉPHÉMÈRE (aucune persistance sur Vercel)
#    Supabase : utiliser le pooler transaction (port 6543)
# -----------------------------------------------------------------------------
# Dev local (docker-compose) :
# DATABASE_URL=postgresql://cfm:cfm_dev_password@localhost:5433/cfm
# Prod Supabase :
DATABASE_URL=
CFM_PG_NORMALIZED=true

# -----------------------------------------------------------------------------
# 4. Stockage médias (Supabase Storage) — OBLIGATOIRE (prod) pour l'upload admin
#    Sans config, fallback disque local (non persistant sur Vercel)
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=media-uploads

# -----------------------------------------------------------------------------
# 5. Paiements — Mobile Money / PayDunya
#    "demo" = simulation (aucun encaissement) ; "production" = PayDunya réel
# -----------------------------------------------------------------------------
MOBILE_MONEY_MODE=demo
NEXT_PUBLIC_MOBILE_MONEY_MODE=demo
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# 6. Temps réel — Pusher (chat live, sondages)
#    Sans config, le live fonctionne mais sans push temps réel
# -----------------------------------------------------------------------------
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# -----------------------------------------------------------------------------
# 7. Notifications Web Push (PWA) — générer : npx web-push generate-vapid-keys
#    Sans config, notifications en mode log seulement
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:contact@cfmasbl.com

# -----------------------------------------------------------------------------
# 8. Email SMTP — sans config, les emails sont loggés (data/emails.log ou console)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CFM <contact@cfmasbl.com>
# Exiger l'envoi SMTP réel en production (bloque si SMTP non configuré)
# CFM_REQUIRE_SMTP=true

# -----------------------------------------------------------------------------
# 9. Rate limit distribué — Upstash Redis REST (recommandé multi-instances/serverless)
#    Sans config, rate limit en mémoire par instance (moins strict)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# 10. Réglages optionnels
# -----------------------------------------------------------------------------
# Cache contenu SSR (secondes, défaut 300)
# CFM_CONTENT_CACHE_TTL=300
# Cache médias SSR (secondes, défaut 300)
# CFM_MEDIA_CACHE_TTL=300
# Compression images upload (Sharp, max 1920px WebP)
# CFM_IMAGE_COMPRESS=true
