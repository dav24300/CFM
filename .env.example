# Mot de passe admin (dashboard /admin)
ADMIN_PASSWORD=changez-moi-en-production

# Secret session (générer une chaîne aléatoire longue, 64+ caractères)
SESSION_SECRET=remplacer-par-une-cle-secrete-longue

# URL publique du site (emails, PayDunya callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mobile Money : "demo" (simulation) ou "production" (PayDunya)
MOBILE_MONEY_MODE=demo
NEXT_PUBLIC_MOBILE_MONEY_MODE=demo

# PayDunya production
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_WEBHOOK_SECRET=

# Email SMTP (optionnel — sans config, les emails sont loggés dans data/emails.log)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CFM <contact@cfmasbl.com>

# PostgreSQL (persistance normalisée — source de vérité en production)
# DATABASE_URL=postgresql://cfm:cfm_dev_password@localhost:5433/cfm
# CFM_PG_NORMALIZED=true
#
# Supabase (production Vercel) — pooler transaction port 6543
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=media-uploads

# Cache contenu SSR (secondes, défaut 300)
# CFM_CONTENT_CACHE_TTL=300

# Cache médias SSR (secondes, défaut 300)
# CFM_MEDIA_CACHE_TTL=300

# Compression images upload (VPS — Sharp, max 1920px WebP)
# CFM_IMAGE_COMPRESS=true

# Rate limit distribué (Upstash Redis REST — obligatoire multi-instances)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Chiffrement données sensibles (aide confidentielle — obligatoire en production)
# DATA_ENCRYPTION_KEY=generer-une-cle-aleatoire-32-caracteres-minimum

# Exiger SMTP en production (emails transactionnels)
# CFM_REQUIRE_SMTP=true

# Web Push (V3 PWA) — générer avec: node scripts/generate-vapid.mjs
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:contact@cfmasbl.com

# Netlify / démo temporaire (optionnel — affiche mode lecture seule)
# CFM_DEMO_READONLY=true
# CFM_SERVERLESS=true
